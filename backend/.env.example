# ═══════════════════════════════════════════════════════════
#  ORION BACKEND — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://orion_user:your_password@localhost:5432/orion_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orion_db
DB_USER=orion_user
DB_PASSWORD=your_secure_password_here
DB_SSL=false

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_never_share_this_value
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Nodemailer / SMTP) ────────────────────────────────
# Option A: SMTP (Gmail, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Option B: Resend (set EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Which provider to use: smtp | resend
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=Orion Observatory
EMAIL_FROM_ADDRESS=noreply@orion.app

# ── Anthropic AI ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ── Podcast Storage ──────────────────────────────────────────
# For local development, files served from /public/audio
# For production, use an S3-compatible bucket
PODCAST_STORAGE=local
PODCAST_BASE_URL=http://localhost:4000/audio

# AWS S3 (optional, for production)
AWS_BUCKET_NAME=orion-podcasts
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
